# ═══════════════════════════════════════════════════════
#  Polymarket Bot — Environment Variables
#  Copy to .env and fill in values before running.
# ═══════════════════════════════════════════════════════

# ── Mode ─────────────────────────────────────────────────────────────────────
DRY_RUN=true                        # Set false for live trading

# ── API / Wallet (required for live trading) ─────────────────────────────────
POLYMARKET_API_BASE=https://clob.polymarket.com
GAMMA_API_BASE=https://gamma-api.polymarket.com
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# ── Capital ───────────────────────────────────────────────────────────────────
BASE_RISK=10.0
MAX_CAPITAL_PER_TRADE=25.0
MAX_TOTAL_CAPITAL_DEPLOYED=200.0

# ── Edge detection ────────────────────────────────────────────────────────────
EDGE_THRESHOLD=0.08
CONFIDENCE_THRESHOLD=0.60

# ── Liquidity ─────────────────────────────────────────────────────────────────
MIN_MARKET_LIQUIDITY=500.0
MAX_SPREAD=0.06
MIN_VOLUME_24H=1000.0

# ── [NEW] Monte Carlo — Student-t fat tails (IMPROVEMENT 2) ──────────────────
MC_ITERATIONS=1000
MC_SIGMA=0.05
MONTE_CARLO_DF=3                    # Lower = heavier tails = more conservative

# ── [NEW] Slippage protection (IMPROVEMENT 3) ─────────────────────────────────
MAX_SLIPPAGE_PERCENT=0.03           # 3% max slippage vs best ask

# ── [NEW] Circuit breaker (IMPROVEMENT 4) ────────────────────────────────────
MAX_DAILY_LOSS_PERCENT=0.05         # 5% of MAX_TOTAL_CAPITAL_DEPLOYED per day
MAX_OPEN_POSITIONS=10
MIN_EXPECTED_RETURN=0.0             # Minimum Monte Carlo mean EV

# ── [NEW] Cross-market detection (IMPROVEMENT 5) ─────────────────────────────
CROSS_MARKET_EDGE_THRESHOLD=0.10    # Min contradiction score to flag

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SEC=10
ORDER_STALE_SEC=120
API_MAX_RETRIES=4
API_RETRY_BACKOFF=2.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=bot.log
